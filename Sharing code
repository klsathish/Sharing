ALTER PROCEDURE [dbo].[SP_LogoutAndEndSessionByUserId]      
(      
   @UserID int      
)      
As      
      
BEGIN      
      
DECLARE @updatedBy nvarchar(50);     
DECLARE @sessionID nvarchar(100);      
    
Declare  @Message varchar(MAX) = '';

select @updatedBy = Username from [dbo].[ADM_User] where UserID = @UserID     
    
SELECT TOP 1 @sessionID = SessionID  FROM [dbo].[TRN_UserLoginSession] where UserID = @UserID and IsActive=1 order by CreatedDate desc    
     
DECLARE @ID Int, @OldValue XML, @NewValue XML, @OldValueTemp NVARCHAR(MAX), @NewValueTemp NVARCHAR(MAX)

Exec SP_GetXMLValueForLog 'ADM_LoginActivity', 'SessionID', @sessionID, @OldValueTemp output      
SET @OldValue = CAST(@OldValueTemp AS XML)

 Update [dbo].[ADM_LoginActivity] set IsOnline=0,UpdatedBy=@UpdatedBy,UpdatedOn=getdate(),LogoutTime=getdate() where  UserID = @UserID AND SessionID=@sessionID  
 
Exec SP_GetXMLValueForLog 'ADM_LoginActivity', 'SessionID', @sessionID, @NewValueTemp output
SET @NewValue = isnull(CAST(@NewValueTemp AS XML),'');
SET @OldValue = isnull(CAST(@OldValueTemp AS XML),'');

Exec SP_GetXMLValueForLog '[TRN_UserLoginSession]', 'UserID', @UserID, @OldValueTemp output      
SET @OldValue = CAST(@OldValueTemp AS XML)

 Update [dbo].[TRN_UserLoginSession] set IsActive=0,UpdatedBy=@UpdatedBy,UpdatedOn=getdate() where  UserID = @UserID 

Exec SP_GetXMLValueForLog '[TRN_UserLoginSession]', 'UserID', @UserID, @NewValueTemp output
SET @NewValue = isnull(CAST(@NewValueTemp AS XML),'');
SET @OldValue = isnull(CAST(@OldValueTemp AS XML),'');

 
 SET @Message = 'User logout and end session has been updated successfully.';

END


ALTER PROCEDURE [dbo].[SP_GetXMLValueForLog]
(
	@Tablename nVarChar(100),
	@IdentityColumn nVarChar(100),
	@ID INT,
	@XMLValue nVarChar(MAX) OUTPUT
)
AS
BEGIN

	SET NOCOUNT ON;
	DECLARE @SQL NVARCHAR(MAX), @Results XML;

	SET @SQL = N'SET @Out = (SELECT * FROM ' + @tablename + ' WHERE ' + @identityColumn + ' = ' + CAST(@ID AS nVarchar(10)) + ' FOR XML AUTO, ELEMENTS);';

	EXEC sp_executesql @SQL, N'@Out XML OUTPUT', @Out = @Results OUTPUT;

	SET @XMLValue = CONVERT(NVARCHAR(MAX), @Results)

END
