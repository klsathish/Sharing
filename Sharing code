	INSERT INTO @tblResult Values(@OpeningInventoryValueInMilionSAR, @OpeningInventoryValueInMilionUSD, @AIForecastValueInMilionSAR, @AIForecastValueInMilionUSD)
	
	SELECT
		RecID
		,ceiling(OpeningInventoryValueInMillionSAR) AS OpeningInventoryValueInMillionSAR
