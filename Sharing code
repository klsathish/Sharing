   public async Task InvokeAsync(HttpContext httpContext)
   {
       httpContext.Request.EnableBuffering();

       var originalResponseBody = httpContext.Response.Body;

       string requestBody = string.Empty;
       string requestParameters = string.Empty;
       string responseBody = string.Empty;

       using var responseBuffer = new MemoryStream();
       httpContext.Response.Body = responseBuffer;

       try
       {
           requestParameters = _requestLoggingService.GetRequestParameters(httpContext);

           if (httpContext.Request.ContentLength.HasValue &&
               httpContext.Request.ContentLength > 0 &&
               !string.Equals(httpContext.Request.Method, "GET", StringComparison.OrdinalIgnoreCase))
           {
               requestBody = await _requestLoggingService.ReadRequestBodyAsync(httpContext.Request);
           }

           await _next(httpContext);


           responseBuffer.Position = 0;
           responseBuffer.Seek(0, SeekOrigin.Begin);
           responseBody = await new StreamReader(responseBuffer).ReadToEndAsync();
           responseBuffer.Seek(0, SeekOrigin.Begin);

           responseBuffer.Position = 0;

           await responseBuffer.CopyToAsync(originalResponseBody);
       }
       catch (Exception ex)
       {

           await HandlerExceptionAsync(
               httpContext,
               ex,
               requestBody,
               requestParameters,
               responseBody);
       }
       finally
       {
           httpContext.Response.Body = originalResponseBody;
       }
   }
