	,@PlantID VARCHAR(max) = NULL
	,@SBU VARCHAR(MAX)=NULL  
	,@BU VARCHAR(MAX)=NULL
	,@FromDate DATETIME = null
	,@ToDate DATETIME = NULL  

SET NOCOUNT ON;

	DECLARE @InventoryType VARCHAR(500)

	IF(@TypeID = 1)
	BEGIN
		SET @InventoryType = 'Raw Materials'
	END
	ELSE IF(@TypeID = 2)
	BEGIN
		SET @InventoryType = 'Finished Goods'
	END
	ELSE
	BEGIN
		SET @InventoryType = 'Raw Materials,Finished Goods'
	END

    IF(@CompanyCode ='1' or @CompanyCode ='0')      
	BEGIN      
		SET @CompanyCode = ''      
	END 

	IF(@ProfitCenterID ='1' or @ProfitCenterID ='0')      
	BEGIN      
		SET @ProfitCenterID = ''      
	END  
	
	IF(@PlantID ='1' or @PlantID ='0')      
	BEGIN      
		SET @PlantID = ''      
	END
		
	DECLARE @tbl_ProfitCenterValues TABLE (profitCenterName NVARCHAR(100));
	INSERT INTO @tbl_ProfitCenterValues(profitCenterName)
	SELECT ProfitCenterName FROM [SABIC_DT_Finance_Master].[master].[MST_ProfitCenter] WHERE ProfitCenterID  in (select * from string_split(@ProfitCenterID,','))

	SET @RegionID = ISNULL(@RegionID, '');
	SET @CountryID = ISNULL(@CountryID, '');
	SET @CompanyCode = ISNULL(@CompanyCode, '');
	SET @SBU = ISNULL(@SBU, '');
	SET @BU = ISNULL(@BU, '');
	SET @ProfitCenterID = ISNULL(@ProfitCenterID, '');
	SET @PlantID = ISNULL(@PlantID, '');
	SET @FromDate = NULLIF(@FromDate, '');
	SET @ToDate = NULLIF(@ToDate, '');

	IF (@FromDate = '' or @FromDate is null or @ToDate = '' or @ToDate is null)
	SELECT
		@FromDate = FromDate
		,@ToDate = ToDate
	FROM
		ADM_DefaultDatesForFilter
	WHERE
		IsActive = 1

	DECLARE @FromCalMonth int, @ToCalMonth int

	SELECT
		@FromCalMonth = cast(
						cast(YEAR(@FromDate) as varchar(4))
						+
						CASE WHEN MONTH(@FromDate) < 10 THEN '0' + cast(MONTH(@FromDate) as varchar(2))
						ELSE cast(MONTH(@FromDate) as varchar(2)) END
					as int)
		,@ToCalMonth  = cast(
						cast(YEAR(@ToDate) as varchar(4))
						+
						CASE WHEN MONTH(@ToDate) < 10 THEN '0' + cast(MONTH(@ToDate) as varchar(2))
						ELSE cast(MONTH(@ToDate) as varchar(2)) END
